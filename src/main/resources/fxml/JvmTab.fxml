<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.vitals.controllers.JvmMonitorController">

    <top>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="5.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="monitor-card" style="-fx-background-color: #ffffff;-fx-border-color: #e1e8ed; -fx-border-width: 1px; -fx-background-radius: 6px; -fx-border-radius: 6px;">
                    <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
                    </padding>
                    <children>
                        <Label text="监控目标:" textFill="#2c3e50">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Label>

                        <javafx.scene.control.ComboBox fx:id="cmbTargetType" prefWidth="120.0" style="-fx-cursor: hand;" />

                        <javafx.scene.control.TextField fx:id="txtJmxUrl" promptText="127.0.0.1:9999 或 service:jmx:rmi://..."
                                                        HBox.hgrow="ALWAYS" disable="true" style="-fx-font-family: 'Consolas';" />

                        <javafx.scene.control.Button fx:id="btnConnect" text="开始监控" onAction="#handleConnect"
                                                     style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 4px; -fx-cursor: hand;">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </javafx.scene.control.Button>
                    </children>
                </HBox>

                <GridPane hgap="15.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="33.3" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="33.4" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="33.3" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <VBox styleClass="monitor-card" stylesheets="@../css/vitals.css" GridPane.columnIndex="0">
                            <padding>
                                <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
                            </padding>
                            <children>
                                <Label text="JVM 堆内存 (Heap)" textFill="#7f8c8d">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <Label fx:id="lblCurrentHeap" text="0.0 MB / 0.0 MB" textFill="#2c3e50">
                                    <font><Font size="20.0" /></font>
                                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                                </Label>
                            </children>
                        </VBox>

                        <VBox styleClass="monitor-card" stylesheets="@../css/vitals.css" GridPane.columnIndex="1">
                            <padding>
                                <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
                            </padding>
                            <children>
                                <Label text="活动线程数 (Threads)" textFill="#7f8c8d">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <Label fx:id="lblThreadCount" text="Threads: 0 (Peak: 0)" textFill="#2c3e50">
                                    <font><Font size="20.0" /></font>
                                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                                </Label>
                            </children>
                        </VBox>

                        <VBox styleClass="monitor-card" stylesheets="@../css/vitals.css" GridPane.columnIndex="2">
                            <padding>
                                <Insets bottom="12.0" left="15.0" right="15.0" top="12.0" />
                            </padding>
                            <children>
                                <Label text="JVM 进程 CPU" textFill="#7f8c8d">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <Label fx:id="lblJvmCpu" text="0.0%" textFill="#2c3e50">
                                    <font><Font size="20.0" /></font>
                                    <VBox.margin><Insets top="5.0" /></VBox.margin>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </GridPane>

            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="15.0" styleClass="content-area" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="5.0" />
            </padding>
            <children>

                <VBox styleClass="chart-container" style="-fx-background-color: #ffffff; -fx-border-color: #e1e8ed; -fx-border-width: 1px; -fx-background-radius: 8px; -fx-border-radius: 8px;">
                    <padding>
                        <Insets bottom="5.0" left="5.0" right="10.0" top="10.0" />
                    </padding>
                    <children>
                        <LineChart fx:id="jvmHeapChart" title="JVM Heap Memory Usage" prefHeight="260.0" animated="false" createSymbols="false" legendVisible="false">
                            <xAxis>
                                <NumberAxis fx:id="xAxis" side="BOTTOM" tickLabelsVisible="false" tickMarkVisible="false" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Memory (MB)" side="LEFT" />
                            </yAxis>
                        </LineChart>
                    </children>
                </VBox>

                <VBox styleClass="chart-container" VBox.vgrow="ALWAYS" spacing="10.0" style="-fx-background-color: #ffffff; -fx-border-color: #e1e8ed; -fx-border-width: 1px; -fx-background-radius: 8px; -fx-border-radius: 8px;">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="12.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="实时线程深度分析" textFill="#34495e">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>

                                <javafx.scene.control.TextField fx:id="txtThreadFilter" promptText="输入线程名或状态(如 exec, BLOCKED)过滤..."
                                                                prefWidth="260.0" style="-fx-font-size: 12px;" />

                                <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />

                                <javafx.scene.control.SplitMenuButton text="导出 Thread Dump" onAction="#handleExportThreadDump"
                                                                      style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-background-radius: 4px; -fx-cursor: hand;">
                                    <items>
                                        <javafx.scene.control.MenuItem text="导出 JVM Heap Dump (.hprof)" onAction="#handleExportHeapDump" />
                                    </items>
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </javafx.scene.control.SplitMenuButton>
                            </children>
                            <padding>
                                <Insets bottom="3.0" />
                            </padding>
                        </HBox>

                        <SplitPane dividerPositions="0.4" orientation="VERTICAL" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                            <items>
                                <TableView fx:id="tblThreads">
                                    <columns>
                                        <TableColumn fx:id="colThreadId" text="ID" prefWidth="60.0" />
                                        <TableColumn fx:id="colThreadName" text="线程名称 (Name)" prefWidth="300.0" />
                                        <TableColumn fx:id="colThreadState" text="状态 (State)" prefWidth="120.0" />
                                        <TableColumn fx:id="colBlockedCount" text="阻塞次数" prefWidth="90.0" />
                                        <TableColumn fx:id="colWaitedCount" text="等待次数" prefWidth="90.0" />
                                    </columns>
                                </TableView>

                                <VBox spacing="5.0">
                                    <padding>
                                        <Insets top="5.0" />
                                    </padding>
                                    <children>
                                        <Label text="当前线程堆栈轨迹 (Stack Trace):" textFill="#7f8c8d">
                                            <font><Font name="System Bold" size="11.0" /></font>
                                        </Label>
                                        <TextArea fx:id="txtStackTrace" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                                                  style="-fx-font-family: 'Consolas', 'Monospace', 'Courier New'; -fx-font-size: 12px; -fx-text-fill: #c0392b;"/>
                                    </children>
                                </VBox>
                            </items>
                        </SplitPane>
                    </children>
                </VBox>

            </children>
        </VBox>
    </center>
</BorderPane>